# Porta HTTP (default 3100, diverso dal diario che usa 3000)
PORT=3100

# Segreto per firmare i cookie di sessione. Genera con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=cambiami-in-una-stringa-casuale-lunga

# Credenziali single-user (plaintext, come nel diario-alimentare).
# In produzione il file .env ha chmod 600.
ADMIN_USER=admin
ADMIN_PASSWORD=password123

# NODE_ENV=production attiva cookie secure (richiede HTTPS via NPM).
# In sviluppo locale lascia vuoto o commentato.
# NODE_ENV=production

# AUTH_ENABLED=false bypassa l'auth per sviluppo rapido.
# AUTH_ENABLED=false
